# 로컬 개발용 변수 샘플. 실제 값은 .dev.vars 에 넣고(gitignore) 커밋하지 않는다.
#
# e2e 는 이 파일이 아니라 `.dev.vars.e2e` 를 쓴다 — Playwright 가 dev 서버를 띄우기 전에
# scripts/e2e-dev-vars.mjs 가 테스트 전용 세션 키로 자동 생성한다(손대지 않아도 된다).
# 지우면 다음 실행에서 새로 만들어진다. 왜 `.dev.vars` 를 안 쓰는지는 AGENTS.md 지뢰 목록.
NEXTJS_ENV=development

# 치지직 category API(client_credentials) — seed(scripts/seed.mjs)·컴포저 카테고리 검색이 쓴다.
# 값은 1Password Environment(chyailokunya-prod)에서 온다. 커밋 금지(불변식 4). 공개 읽기(게임
# 보드)는 이게 없어도 된다 — games 스냅샷만 읽으므로 외부 API 에 무관하다(ADR-0015).
# CHZZK_CLIENT_ID=
# CHZZK_CLIENT_SECRET=

# 인증(Phase 4, ADR-0017). 로컬 로그인 테스트에 필요하다. 프로덕션은 Cloudflare secret /
# 1Password Environment(chyailokunya-prod)로 주입한다. 커밋 금지(불변식 4).
#   JWT_SIGNING_JWK       EdDSA(Ed25519) private JWK(JSON) — access 서명. `npm run gen-jwt-keys` 로 생성.
#   JWT_PUBLIC_JWK        같은 키쌍의 public JWK(JSON) — access 검증. 위 스크립트가 함께 출력한다.
#   SUPERADMIN_CHANNEL_ID 최초 로그인 시 superadmin 으로 부트스트랩할 치지직 channelId.
#   AUTH_URL              콜백 origin. 로컬은 http://localhost:3000, 프로덕션은 배포 도메인.
#                         치지직 앱에 {AUTH_URL}/api/auth/callback/chzzk 를 redirect URI 로
#                         등록한다. 실제 라우트(src/app/api/auth/callback/chzzk)와 한 글자라도
#                         다르면 동의 화면에서 403 이 난다 — /chzzk 세그먼트를 빠뜨리지 말 것.
# JWT_SIGNING_JWK=
# JWT_PUBLIC_JWK=
# SUPERADMIN_CHANNEL_ID=
# AUTH_URL=http://localhost:3000
