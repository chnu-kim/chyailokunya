{
  "name": "chyailokunya",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project=smoke",
    "e2e:visual": "playwright test --project=visual",
    "e2e:visual:update": "playwright test --project=visual --update-snapshots",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/runner": "^4.1.10",
    "@vitest/snapshot": "^4.1.10",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.4": true,
    "sharp@0.34.5": true,
    "workerd@1.20260714.1": true,
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true,
    "unrs-resolver@1.12.2": true
  }
}
